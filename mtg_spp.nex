	AN C = 16  A = 0 DC = 2022.9.10.23.51.3 DM = 2026.2.28.19.48.16 ID = 018329627c6e233 I = _ TF = (CM 'Villalobos et al 2022^n') TF = (R '#34 Villalobos et al. 2022^n#44 Landemaine et al. 2018^n#4 Shirai 1996^nShirai 1996');

	AN C = 18  A = 0 DC = 2022.6.21.13.57.29 DM = 2026.3.1.12.22.46 ID = 0181861ff23860 I = _ TF = (CM '=POC - preorbital canal in Shirai 1992^nConnects the orbital region with the nasal capsule') TF = (R #26_Landemaine_et_al._2018);

	AN C = 19  A = 0 DC = 2022.6.20.10.19.50 DM = 2022.9.9.10.32.17 ID = 0181803251e849 I = _ TF = (CM present) ;

	AN C = 20  A = 0 DC = 2022.6.20.10.44.47 DM = 2026.3.1.14.5.44 ID = 018180492ab051 I = _ TF = (CM 'Following Carvalho 1996, it is a ventrally projecting process originating on the posterior wall of the nasal capsule and is lying beneath the orbitonasal canal (which is connecting the nasal and orbital venous sinuses). only in chalmydoselchus, echinorhinus and hexanchoids ^nlong ectethmoid processes from the nasal capulses a synapomorphy of Hexanchoids (Compagno^n^nThe process originating from the nasal casules seen in many carcharhiniform sharks is not projecting ventrally and thus isn''t homologous to the ectethmoid process according to Carvalho.^n^nAccording to Carvalho (1996), the ectethmoidal process is only present in hexanchiforms and echinorhinus. Shirai 1992 however argues that this structure is also present (although reduced) in some squaliforms, e.g., Squalus and Zameus. We follow Shirai''s interpretation here in these two taxa.') TF = (R '#7 Landemaine et al. 2018^n#8 Carvalho 1996^nCompagno 1999');

	AN C = 21  A = 0 DC = 2022.7.26.17.47.53 DM = 2026.3.1.9.19.37 ID = 01823b31778f297 I = _ TF = (CM 'Following Carvalho 1996, it is a ventrally projecting process originating on the posterior wall of the nasal capsule and is lying beneath the orbitonasal canal (which is connecting the nasal and orbital venous sinuses).^npresent in all batomorphs (villalobos 2022)^n^nThe process originating from the nasal casules seen in many carcharhiniform sharks is not projecting ventrally and thus isn''t homologous to the ectethmoid process according to Carvalho.^n^nAccording to Carvalho (1996), the ectethmoidal process is only present in hexanchiforms and echinorhinus. Shirai 1992 however argues that this structure is also present (although reduced) in some squaliforms, e.g., Squalus and Zameus. We follow Shirai''s interpretation here in these two taxa.') TF = (R '#7 Landemaine et al. 2018^n#8 Carvalho 1996^nCompagno 1999');

	AN C = 22  A = 0 DC = 2026.2.28.21.1.34 DM = 2026.3.1.9.21.1 ID = 019ca7c5f5c5329 I = _ TF = (CM 'in the batomorphs with antorbital cartilage, most have a regular outline ^nthere is an irregular outline/irregular shape in Platyrhinidae and electric rays (Villalobos 2019) ') ;

	AN C = 25  A = 0 DC = 2026.3.1.11.57.21 DM = 2026.3.1.11.57.21 ID = 019caafa1130333 I = _ TF = (CM ) ;

